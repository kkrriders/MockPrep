# MockPrep — Environment Configuration
# Copy to .env and fill in values before starting.

# ── Required ──────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=
MONGODB_URI=mongodb://localhost:27017/mockprep
FRONTEND_URL=http://localhost:3002

# ── Groq API (required) ───────────────────────────────────────────────────────
# Free tier — get your key at https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_key_here

# ── OpenRouter (optional fallback) ───────────────────────────────────────────
# Used automatically if Groq quota is exhausted
# Free keys at https://openrouter.ai
OPENROUTER_API_KEY=
OPENROUTER_DEFAULT_MODEL=meta-llama/llama-3.1-8b-instruct:free

# ── Research Agent (optional) ─────────────────────────────────────────────────
# Powers live company research that tailors interview questions to candidate CV
# Free tier: 1,000 searches/month — get key at https://tavily.com
TAVILY_API_KEY=

# ── Google OAuth (optional) ───────────────────────────────────────────────────
# Create credentials at: https://console.cloud.google.com → APIs & Services → Credentials
# Set Authorized redirect URI to: http://localhost:3000/api/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ── LinkedIn OAuth (optional) ─────────────────────────────────────────────────
# Create app at: https://www.linkedin.com/developers/apps
# Add OAuth 2.0 redirect URL: http://localhost:3000/api/auth/linkedin/callback
# Required products: Sign In with LinkedIn using OpenID Connect
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# ── Backend URL (optional, for OAuth redirect URIs) ───────────────────────────
# Only needed if your backend is not at http://localhost:3000
BACKEND_URL=http://localhost:3000

# ── Optional ──────────────────────────────────────────────────────────────────
# Redis for persistent rate limiting (falls back to in-memory if not set)
REDIS_URL=redis://localhost:6379

# Server port (default: 3000)
PORT=3000

# Logging level: error | warn | info | debug
LOG_LEVEL=info

# Node environment: development | production
NODE_ENV=development
